#!/bin/bash

# 1. Path Discovery
# Dynamically handles the user home and project name
WORKSPACE_DIR="$HOME/${PROJECT_NAME:-docker_template}"

# 2. Load Environment Variables (Single Source of Truth)
if [ -f "$WORKSPACE_DIR/.env" ]; then
    export $(grep -v '^#' "$WORKSPACE_DIR/.env" | xargs)
fi

# 3. Source Standard ROS 2 Jazzy (Underlay)
if [ -f "/opt/ros/jazzy/setup.bash" ]; then
    source /opt/ros/jazzy/setup.bash
    source /usr/share/colcon_argcomplete/hook/colcon-argcomplete.bash
fi

# 4. Source Project Workspace (Overlay)
if [ -f "${WORKSPACE_DIR}/install/setup.bash" ]; then
    source "${WORKSPACE_DIR}/install/setup.bash"
    echo "Sourced workspace: ${PROJECT_NAME}"
fi

# 5. Safe Build Function
# We use a function instead of an alias to allow for RAM calculation
build() {
    # 1. Calculate safe jobs: ~2GB RAM per thread is the ROS 2 safe zone
    local ram_gb=$(free -g | awk '/^Mem:/{print $2}')
    local safe_jobs=$(( ram_gb / 2 ))
    
    # Constraints: Never 0, never more than 2 for dev (to keep UI smooth)
    [[ $safe_jobs -lt 1 ]] && safe_jobs=1
    [[ $safe_jobs -gt 2 ]] && safe_jobs=2 

    echo "--- Starting Safe Build (${safe_jobs} threads, Sequential) ---"

    # 2. Force threading limits into the environment so CMake/Make obey
    export MAKEFLAGS="-j${safe_jobs}"
    export CMAKE_BUILD_PARALLEL_LEVEL=${safe_jobs}

    # 3. Execute Build
    # --executor sequential: Only one package at a time
    # --parallel-workers: Hard limit on package concurrency
    colcon build \
        --symlink-install \
        --executor sequential \
        --parallel-workers "$safe_jobs" \
        --cmake-args -DCMAKE_BUILD_TYPE=RelWithDebInfo \
        "$@"
}

# 6. Essential Aliases & Utilities
alias sros="source ${WORKSPACE_DIR}/install/setup.bash"
alias rt='ros2 topic list'
alias rn='ros2 node list'
alias cbp='colcon build --symlink-install --packages-select'

# A "Nuke" command to fix CMakeCache mismatch issues
clean_build() {
    read -p "Delete build, install, and log folders? (y/n): " confirm
    if [[ $confirm == [yY] ]]; then
        rm -rf "${WORKSPACE_DIR}/build" "${WORKSPACE_DIR}/install" "${WORKSPACE_DIR}/log"
        echo "Workspace cleaned."
    fi
}

echo "-------------------------------------------------------"
echo "  ROS 2 Jazzy: ${PROJECT_NAME:-docker_template}"
echo "  User: $(whoami) | Home: $HOME"
echo "  Commands: build, clean_build, sros, rt, rn"
echo "-------------------------------------------------------"
